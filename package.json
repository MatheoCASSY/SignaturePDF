{
  "name": "pdfme",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "vercel:pull": "npx vercel pull --yes --environment=production",
    "vercel:build:prebuilt": "npx vercel build --prod",
    "vercel:deploy:prebuilt": "npx vercel deploy --prebuilt --prod",
    "vercel:prebuilt": "npm run vercel:pull && npm run vercel:build:prebuilt && npm run vercel:deploy:prebuilt"
  },
  "dependencies": {
    "@pdfme/common": "^6.0.6",
    "@pdfme/schemas": "^6.0.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  }
}
